{
  "version": 1,
  "rules_path": "apps/wechat_ai_customer_service/configs/platform_fallback_rules.example.json",
  "state_path": "runtime/apps/wechat_ai_customer_service/state/guarded_workflow_state.json",
  "audit_log_path": "runtime/apps/wechat_ai_customer_service/logs/audit.jsonl",
  "poll": {
    "interval_seconds": 15,
    "iterations": 1
  },
  "state_lock": {
    "timeout_seconds": 120,
    "stale_seconds": 900
  },
  "rate_limits": {
    "min_seconds_between_replies": 0,
    "max_replies_per_10_minutes": 20,
    "max_replies_per_hour": 100,
    "notice_customer": true,
    "notice_min_interval_seconds": 300,
    "notice_reply": "当前自动客服用量已超，已达到{reason_label}上限，请稍等约 {retry_after_minutes} 分钟，冷却后我会继续处理您的消息。"
  },
  "reply": {
    "prefix": "[OmniAuto客服] ",
    "allow_fallback_send": false
  },
  "rag_response": {
    "enabled": true,
    "apply_to_unmatched": true,
    "apply_to_matched_product": false,
    "apply_to_small_talk": false,
    "skip_llm_after_apply": true,
    "min_hit_score": 0.12,
    "max_reply_chars": 220,
    "max_snippet_chars": 130
  },
  "llm_reply_synthesis": {
    "enabled": false,
    "provider": "manual_json",
    "mode": "guarded_auto",
    "shadow_mode": false,
    "require_evidence": true,
    "require_structured_for_authority": true,
    "fallback_to_existing_reply": true,
    "max_history_messages": 40,
    "history_char_budget": 12000,
    "max_rag_hits": 5,
    "max_rag_text_chars": 900,
    "max_catalog_candidates": 8,
    "quality_priority": true,
    "model_routing": {
      "enabled": true,
      "default_tier": "flash",
      "flash_model": "deepseek-v4-flash",
      "pro_model": "deepseek-v4-pro",
      "force_model_tier": "",
      "pro_intent_tags": [
        "payment",
        "invoice",
        "after_sales",
        "handoff",
        "customer_data"
      ],
      "pro_safety_reasons": [
        "matched_faq_requires_handoff",
        "invoice_amount_entity",
        "contract_risk",
        "payment_boundary",
        "price_approval_required"
      ],
      "pro_when_must_handoff": true,
      "pro_when_rag_only_authority": true,
      "pro_when_long_context": false,
      "pro_when_long_message": false,
      "pro_min_history_count": 80,
      "pro_min_message_chars": 420
    },
    "profiles": {
      "flash": {
        "max_history_messages": 12,
        "history_char_budget": 5000,
        "max_rag_hits": 3,
        "max_rag_text_chars": 360,
        "max_catalog_candidates": 5,
        "max_tokens": 1800,
        "temperature": 0.35
      },
      "pro": {
        "max_history_messages": 40,
        "history_char_budget": 12000,
        "max_rag_hits": 5,
        "max_rag_text_chars": 900,
        "max_catalog_candidates": 8,
        "max_tokens": 3200,
        "temperature": 0.38
      }
    },
    "cost_controls": {
      "enabled": true,
      "max_llm_calls_per_run": 0,
      "skip_llm_when_deterministic_reply": false,
      "safe_deterministic_rule_names": []
    },
    "min_confidence": 0.62,
    "max_reply_chars": 520,
    "max_tokens": 3200,
    "temperature": 0.38,
    "retry_count": 2,
    "include_evidence_pack_in_audit": false,
    "candidate_json_path": "",
    "platform_safety_rules_path": "apps/wechat_ai_customer_service/configs/platform_safety_rules.example.json",
    "platform_understanding_rules_path": "apps/wechat_ai_customer_service/configs/platform_understanding_rules.example.json"
  },
  "data_capture": {
    "enabled": true,
    "workbook_path": "runtime/apps/wechat_ai_customer_service/test_artifacts/customer_leads.xlsx",
    "sheet_name": "客户线索",
    "required_fields": [
      "name",
      "phone"
    ],
    "write_on_send_only": false,
    "success_reply": "客户资料已记录，我会尽快为您继续处理。",
    "incomplete_reply": "我看到了客户资料，但还缺少：{missing_fields}。请补充后我再记录。"
  },
  "product_knowledge": {
    "enabled": false,
    "path": "apps/wechat_ai_customer_service/data/compiled/structured_compat/product_knowledge.example.json"
  },
  "handoff": {
    "enabled": true,
    "auto_acknowledge": true,
    "acknowledgement_reply": "这个问题我当前无法直接确认，我先帮您记录并请示上级，稍后给您准确回复。"
  },
  "operator_alert": {
    "enabled": true,
    "alert_log_path": "runtime/apps/wechat_ai_customer_service/logs/operator_alerts.jsonl"
  },
  "service_profile": {
    "role": "谨慎、真实、不过度承诺的微信客服",
    "tone": "简短、礼貌、像真人客服",
    "answer_boundary": "只按规则库、产品知识库和明确授权回答；缺少依据或涉及让利、破例、售后争议时转人工。"
  },
  "intent_assist": {
    "enabled": false,
    "mode": "heuristic",
    "advisory_only": true,
    "llm_advisory": {
      "enabled": false,
      "provider": "manual_json",
      "advisory_only": true,
      "include_prompt_in_audit": false,
      "candidate_json_path": ""
    }
  },
  "targets": [
    {
      "name": "文件传输助手",
      "enabled": true,
      "exact": true,
      "allow_self_for_test": true,
      "max_batch_messages": 3
    }
  ]
}
