# PostgreSQL storage example for WeChat AI customer-service.
# Copy the values into your shell environment or a local .env file that is not committed.

WECHAT_STORAGE_BACKEND=postgres
WECHAT_POSTGRES_DSN=postgresql://omniauto:omniauto@127.0.0.1:5432/omniauto
WECHAT_POSTGRES_SCHEMA=wechat_ai_customer_service

# Keep enabled so PostgreSQL writes are mirrored back to JSON files as a backup/fallback source.
# Set to 0 only for production deployments that intentionally manage backups outside the app.
WECHAT_POSTGRES_MIRROR_FILES=1
