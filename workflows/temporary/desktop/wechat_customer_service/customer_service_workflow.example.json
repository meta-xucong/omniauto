{
  "version": 1,
  "rules_path": "workflows/temporary/desktop/wechat_customer_service/customer_service_rules.example.json",
  "state_path": "runtime/state/wechat_customer_service/guarded_workflow_state.json",
  "audit_log_path": "runtime/logs/wechat_customer_service/audit.jsonl",
  "poll": {
    "interval_seconds": 15,
    "iterations": 1
  },
  "state_lock": {
    "timeout_seconds": 120,
    "stale_seconds": 900
  },
  "rate_limits": {
    "min_seconds_between_replies": 0,
    "max_replies_per_10_minutes": 20,
    "max_replies_per_hour": 100,
    "notice_customer": true,
    "notice_min_interval_seconds": 300,
    "notice_reply": "当前自动客服用量已超，已达到{reason_label}上限，请稍等约 {retry_after_minutes} 分钟，冷却后我会继续处理您的消息。"
  },
  "reply": {
    "prefix": "[OmniAuto客服] ",
    "allow_fallback_send": false
  },
  "data_capture": {
    "enabled": true,
    "workbook_path": "runtime/test_artifacts/wechat_customer_service/customer_leads.xlsx",
    "sheet_name": "客户线索",
    "required_fields": ["name", "phone"],
    "write_on_send_only": false,
    "success_reply": "客户资料已记录，我会尽快为您继续处理。",
    "incomplete_reply": "我看到了客户资料，但还缺少：{missing_fields}。请补充后我再记录。"
  },
  "product_knowledge": {
    "enabled": false,
    "path": "workflows/temporary/desktop/wechat_customer_service/product_knowledge.example.json"
  },
  "handoff": {
    "enabled": true,
    "auto_acknowledge": true,
    "acknowledgement_reply": "这个问题我当前无法直接确认，我先帮您记录并请示上级，稍后给您准确回复。"
  },
  "operator_alert": {
    "enabled": true,
    "alert_log_path": "runtime/logs/wechat_customer_service/operator_alerts.jsonl"
  },
  "service_profile": {
    "role": "谨慎、真实、不过度承诺的微信客服",
    "tone": "简短、礼貌、像真人客服",
    "answer_boundary": "只按规则库、产品知识库和明确授权回答；缺少依据或涉及让利、破例、售后争议时转人工。"
  },
  "intent_assist": {
    "enabled": false,
    "mode": "heuristic",
    "advisory_only": true,
    "llm_advisory": {
      "enabled": false,
      "provider": "manual_json",
      "advisory_only": true,
      "include_prompt_in_audit": false,
      "candidate_json_path": ""
    }
  },
  "targets": [
    {
      "name": "文件传输助手",
      "enabled": true,
      "exact": true,
      "allow_self_for_test": true,
      "max_batch_messages": 3
    }
  ]
}
