<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ keyword }} - {{ site }} 调研报告</title>
  <style>
    :root {
      --ink: #0f172a;
      --text: #334155;
      --muted: #64748b;
      --line: #e2e8f0;
      --surface: #ffffff;
      --surface-raised: #f8fafc;
      --surface-hover: #f1f5f9;
      --radius: 12px;
      --shadow: 0 1px 3px rgba(0,0,0,0.04), 0 4px 12px rgba(0,0,0,0.03);
    }
    * { box-sizing: border-box; }
    body {
      font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
      margin: 0;
      padding: 40px 24px;
      background: #f4f6f8;
      color: var(--ink);
      line-height: 1.55;
      font-size: 14px;
      letter-spacing: -0.01em;
    }
    .container {
      max-width: 1400px;
      margin: 0 auto;
      background: var(--surface);
      padding: 40px;
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      border: 1px solid var(--line);
    }
    h1 {
      font-size: 28px;
      font-weight: 700;
      letter-spacing: -0.03em;
      margin: 0 0 6px;
      line-height: 1.2;
    }
    .meta {
      color: var(--muted);
      font-size: 13px;
      margin-bottom: 28px;
    }
    .stats {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 14px;
      margin-bottom: 32px;
    }
    .stat-card {
      min-height: 86px;
      padding: 18px;
      border-radius: var(--radius);
      border: 1px solid var(--line);
      background: var(--surface-raised);
      text-align: left;
      transition: transform 0.15s ease, box-shadow 0.15s ease;
    }
    .stat-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(0,0,0,0.05);
    }
    .stat-card .number {
      font-size: 26px;
      font-weight: 700;
      letter-spacing: -0.03em;
      color: var(--ink);
      line-height: 1.15;
    }
    .stat-card .label {
      font-size: 12px;
      color: var(--muted);
      margin-top: 6px;
      font-weight: 500;
    }
    .stat-card.skip {
      background: #fef2f2;
      border-color: #fecaca;
    }
    .stat-card.skip .number { color: #991b1b; }

    h2 {
      margin-top: 36px;
      font-size: 18px;
      font-weight: 600;
      letter-spacing: -0.02em;
      padding-bottom: 10px;
      border-bottom: 1px solid var(--line);
    }
    .section-desc {
      color: var(--muted);
      font-size: 13px;
      margin: 8px 0 16px;
    }
    table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      margin-top: 16px;
      font-size: 13px;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      overflow: hidden;
    }
    thead {
      background: var(--surface-raised);
    }
    th, td {
      padding: 10px 12px;
      text-align: left;
      vertical-align: top;
      border-bottom: 1px solid var(--line);
    }
    th {
      font-weight: 600;
      font-size: 12px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    tbody tr:hover {
      background: var(--surface-hover);
    }
    tbody tr:last-child td {
      border-bottom: none;
    }
    .price {
      color: #991b1b;
      font-weight: 600;
    }
    .item-card {
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 20px;
      margin-bottom: 16px;
      display: flex;
      gap: 18px;
      background: var(--surface);
      transition: box-shadow 0.15s ease;
    }
    .item-card:hover {
      box-shadow: 0 4px 16px rgba(0,0,0,0.04);
    }
    .item-card img {
      width: 120px;
      height: 120px;
      object-fit: cover;
      border-radius: 8px;
      border: 1px solid var(--line);
      flex-shrink: 0;
    }
    .item-info { flex: 1; min-width: 0; }
    .item-title {
      font-size: 16px;
      font-weight: 600;
      margin-bottom: 8px;
      letter-spacing: -0.01em;
      line-height: 1.35;
    }
    .item-meta {
      font-size: 13px;
      color: var(--muted);
      margin-bottom: 5px;
      line-height: 1.5;
    }
    .params {
      font-size: 12px;
      color: var(--text);
      background: var(--surface-raised);
      padding: 12px;
      border-radius: 8px;
      margin-top: 10px;
      border: 1px solid var(--line);
    }
    .params-label {
      font-weight: 600;
      color: var(--ink);
      margin-bottom: 8px;
      font-size: 12px;
    }
    .params-list {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }
    .param-chip {
      display: inline-flex;
      align-items: center;
      max-width: 100%;
      line-height: 1.45;
      background: #fff;
      border: 1px solid var(--line);
      border-radius: 999px;
      padding: 4px 10px;
      font-size: 12px;
    }
    .screenshot-link {
      display: inline-block;
      margin-top: 12px;
      cursor: zoom-in;
      border-radius: 8px;
      overflow: hidden;
      border: 1px solid var(--line);
    }
    .screenshot {
      display: block;
      max-width: 240px;
      max-height: 180px;
      transition: transform 0.2s ease;
    }
    .screenshot-link:hover .screenshot {
      transform: scale(1.02);
    }
    .error-badge {
      display: inline-flex;
      align-items: center;
      background: #fef2f2;
      color: #991b1b;
      padding: 3px 10px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 500;
      margin-left: 8px;
      border: 1px solid #fecaca;
    }
    .empty {
      color: var(--muted);
      margin-top: 16px;
      font-size: 13px;
    }
    .small {
      font-size: 12px;
      color: var(--muted);
    }
    .lightbox {
      position: fixed;
      inset: 0;
      background: rgba(15, 23, 42, 0.88);
      display: none;
      align-items: center;
      justify-content: center;
      padding: 32px;
      z-index: 9999;
    }
    .lightbox.open { display: flex; }
    .lightbox-inner { position: relative; max-width: 96vw; max-height: 92vh; }
    .lightbox img {
      display: block;
      max-width: 96vw;
      max-height: 92vh;
      border-radius: 8px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.35);
      background: #fff;
    }
    .lightbox-close {
      position: absolute;
      top: -16px;
      right: -16px;
      width: 36px;
      height: 36px;
      border: none;
      border-radius: 999px;
      background: #fff;
      color: var(--ink);
      font-size: 22px;
      line-height: 1;
      cursor: pointer;
      box-shadow: 0 4px 14px rgba(0,0,0,0.18);
      transition: transform 0.15s ease;
    }
    .lightbox-close:hover { transform: scale(1.08); }
    .lightbox-hint {
      margin-top: 12px;
      text-align: center;
      color: #cbd5e1;
      font-size: 12px;
    }
    @media (max-width: 720px) {
      body { padding: 16px; }
      .container { padding: 20px; }
      .stats { grid-template-columns: repeat(2, 1fr); }
      .item-card { flex-direction: column; }
      .item-card img { width: 100%; height: auto; }
      table { font-size: 12px; }
      th, td { padding: 8px; }
    }
  </style>
</head>
<body>
  <div class="container">
    {% set stats = namespace(min_price_text='-', min_price_num=None) %}
    {% for it in all_items | default([]) %}
      {% if it.price_num is not none and (stats.min_price_text == '-' or it.price_num < stats.min_price_num) %}
        {% set stats.min_price_text = it.price_text %}
        {% set stats.min_price_num = it.price_num %}
      {% endif %}
    {% endfor %}
    <h1>{{ keyword }} - {{ site }} 调研报告</h1>
    <div class="meta">生成时间: {{ generated_at | default('') }} · 数据来源: {{ site | default('') }}</div>

    <div class="stats">
      <div class="stat-card">
        <div class="number">{{ total_items | default(0) }}</div>
        <div class="label">抓取商品总数</div>
      </div>
      <div class="stat-card">
        <div class="number">{{ detail_sample_completed | default(sample_size | default(0)) }}</div>
        <div class="label">详情页抽样数</div>
      </div>
      <div class="stat-card skip">
        <div class="number">{{ skip_count | default(0) }}</div>
        <div class="label">因验证跳过</div>
      </div>
      <div class="stat-card">
        <div class="number">{{ stats.min_price_text }}</div>
        <div class="label">最低价格</div>
      </div>
      <div class="stat-card">
        <div class="number">{{ list_pages_completed | default(0) }}</div>
        <div class="label">完成列表页数</div>
      </div>
    </div>

    <h2>全部商品汇总表</h2>
    <p class="section-desc">列出所有从列表页抓取到的商品，按页面实际抓取顺序展示；搜索条件仍为价格排序。</p>
    {% if all_items %}
    <div style="overflow-x: auto;">
      <table>
        <thead>
          <tr>
            <th>#</th>
            <th>商品标题</th>
            <th>价格</th>
            <th>店铺</th>
            <th>来源页</th>
            <th>链接</th>
          </tr>
        </thead>
        <tbody>
          {% for it in all_items %}
          <tr>
            <td>{{ loop.index }}</td>
            <td>{{ it.title | default('') }}</td>
            <td class="price">{{ it.price_text | default('') }}</td>
            <td>{{ it.shop_name | default('') }}</td>
            <td>{{ it.source_page | default('') }}</td>
            <td class="small">{{ it.link | default('') }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% else %}
    <div class="empty">本次没有抓到列表页商品。</div>
    {% endif %}

    <h2>抽样商品详情</h2>
    <p class="section-desc">仅展示成功进入详情页并提取到信息的商品。若出现红色标签，表示该商品在详情页阶段遇到了异常或验证。</p>
    {% if items %}
      {% for it in items %}
      <div class="item-card">
        {% if it.image %}
        <img src="{{ it.image }}" alt="">
        {% endif %}
        <div class="item-info">
          <div class="item-title">
            {{ it.title | default('') }}
            {% if it.detail_error %}
            <span class="error-badge">{{ it.detail_error }}</span>
            {% endif %}
          </div>
          <div class="item-meta">价格: <span class="price">{{ it.price_text | default('') }}</span></div>
          <div class="item-meta">店铺: {{ it.detail.shop_name if it.detail and it.detail.shop_name else it.shop_name | default('') }}</div>
          <div class="item-meta">地区: {{ it.detail.location if it.detail and it.detail.location else '-' }}</div>
          <div class="item-meta">经营模式: {{ it.detail.business_model if it.detail and it.detail.business_model else '-' }}</div>
          <div class="item-meta">链接: {{ it.link | default('') }}</div>
          {% if it.detail and it.detail.params %}
          <div class="params">
            <div class="params-label">参数</div>
            <div class="params-list">
              {% for pair in it.detail.params %}
                {% if pair is mapping %}
                <span class="param-chip">{{ (pair.name | default('') | replace('\t', ' ') | replace('\n', ' ') | trim) ~ ': ' ~ (pair.value | default('') | replace('\t', ' ') | replace('\n', ' ') | trim) }}</span>
                {% else %}
                <span class="param-chip">{{ pair | replace('\t', ' ') | replace('\n', ' ') | trim }}</span>
                {% endif %}
              {% endfor %}
            </div>
          </div>
          {% elif it.detail and it.detail.raw_text %}
          <div class="params">{{ it.detail.raw_text }}</div>
          {% endif %}
          {% if it.screenshot %}
          <a class="screenshot-link" href="{{ it.screenshot }}" data-lightbox-src="{{ it.screenshot }}">
            <img class="screenshot" src="{{ it.screenshot }}" alt="page screenshot">
          </a>
          {% endif %}
        </div>
      </div>
      {% endfor %}
    {% else %}
    <div class="empty">本次没有详情抽样结果。</div>
    {% endif %}
  </div>
  <div class="lightbox" id="report-lightbox" aria-hidden="true">
    <div class="lightbox-inner">
      <button class="lightbox-close" type="button" aria-label="关闭">×</button>
      <img id="report-lightbox-image" src="" alt="enlarged screenshot">
      <div class="lightbox-hint">点击空白处或右上角关闭</div>
    </div>
  </div>
  <script>
    (() => {
      const lightbox = document.getElementById('report-lightbox');
      const lightboxImage = document.getElementById('report-lightbox-image');
      const closeButton = lightbox.querySelector('.lightbox-close');
      const open = (src) => {
        lightboxImage.src = src;
        lightbox.classList.add('open');
        lightbox.setAttribute('aria-hidden', 'false');
      };
      const close = () => {
        lightbox.classList.remove('open');
        lightbox.setAttribute('aria-hidden', 'true');
        lightboxImage.src = '';
      };
      document.querySelectorAll('[data-lightbox-src]').forEach((link) => {
        link.addEventListener('click', (event) => {
          event.preventDefault();
          open(link.getAttribute('data-lightbox-src'));
        });
      });
      lightbox.addEventListener('click', (event) => {
        if (event.target === lightbox) { close(); }
      });
      closeButton.addEventListener('click', close);
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && lightbox.classList.contains('open')) { close(); }
      });
    })();
  </script>
</body>
</html>
