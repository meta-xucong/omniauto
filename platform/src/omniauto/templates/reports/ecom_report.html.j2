<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <title>{{ keyword }} — {{ site }} 调研报告</title>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif; margin: 40px; background: #f8f9fa; color: #333; }
    .container { max-width: 1400px; margin: 0 auto; background: #fff; padding: 32px; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
    h1 { font-size: 28px; margin-bottom: 8px; }
    .meta { color: #666; margin-bottom: 24px; }
    .stats { display: flex; gap: 16px; margin-bottom: 24px; flex-wrap: wrap; }
    .stat-card { flex: 1; min-width: 140px; background: #f1f5f9; padding: 16px; border-radius: 6px; text-align: center; }
    .stat-card .number { font-size: 24px; font-weight: 700; color: #0f172a; }
    .stat-card .label { font-size: 12px; color: #64748b; margin-top: 4px; }
    .stat-card.skip { background: #fef2f2; }
    .stat-card.skip .number { color: #dc2626; }
    h2 { margin-top: 32px; font-size: 20px; border-bottom: 1px solid #e2e8f0; padding-bottom: 8px; }
    table { width: 100%; border-collapse: collapse; margin-top: 16px; font-size: 13px; }
    th, td { border: 1px solid #e2e8f0; padding: 8px; text-align: left; vertical-align: top; }
    th { background: #f8fafc; font-weight: 600; }
    tr:nth-child(even) { background: #fafafa; }
    .price { color: #dc2626; font-weight: 600; }
    .item-card { border: 1px solid #e2e8f0; border-radius: 6px; padding: 16px; margin-bottom: 16px; display: flex; gap: 16px; }
    .item-card img { width: 120px; height: 120px; object-fit: cover; border-radius: 4px; border: 1px solid #e2e8f0; }
    .item-info { flex: 1; }
    .item-title { font-size: 16px; font-weight: 600; margin-bottom: 6px; }
    .item-meta { font-size: 13px; color: #64748b; margin-bottom: 6px; }
    .params { font-size: 12px; color: #475569; background: #f8fafc; padding: 8px; border-radius: 4px; margin-top: 6px; }
    .screenshot { margin-top: 8px; max-width: 100%; border: 1px solid #e2e8f0; border-radius: 4px; }
    .error-badge { display: inline-block; background: #fee2e2; color: #991b1b; padding: 2px 8px; border-radius: 4px; font-size: 12px; margin-left: 8px; }
    .section-desc { color: #64748b; font-size: 13px; margin-top: -8px; margin-bottom: 12px; }
  </style>
</head>
<body>
  <div class="container">
    <h1>{{ keyword }} — {{ site }} 调研报告</h1>
    <div class="meta">生成时间: {{ generated_at | default('') }} | 数据来源: {{ site }}</div>

    <div class="stats">
      <div class="stat-card">
        <div class="number">{{ total_items }}</div>
        <div class="label">抓取商品总数</div>
      </div>
      <div class="stat-card">
        <div class="number">{{ sample_size }}</div>
        <div class="label">详情页抽样数</div>
      </div>
      <div class="stat-card skip">
        <div class="number">{{ skip_count | default(0) }}</div>
        <div class="label">因验证跳过</div>
      </div>
      <div class="stat-card">
        <div class="number">{{ items[0].price_text | default('—') }}</div>
        <div class="label">最低价格</div>
      </div>
    </div>

    <h2>全部商品汇总表</h2>
    <p class="section-desc">列出所有从列表页抓取到的商品（按价格从低到高排序）。</p>
    <div style="overflow-x: auto;">
      <table>
        <thead>
          <tr><th>#</th><th>商品标题</th><th>价格</th><th>店铺</th></tr>
        </thead>
        <tbody>
          {% for it in all_items %}
          <tr>
            <td>{{ loop.index }}</td>
            <td>{{ it.title }}</td>
            <td class="price">{{ it.price_text }}</td>
            <td>{{ it.shop_name | default('—') }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    <h2>抽样商品详情</h2>
    <p class="section-desc">仅展示成功进入详情页并提取到信息的商品。若出现红色标签，表示该商品因验证被跳过。</p>
    {% for it in items %}
    <div class="item-card">
      {% if it.image %}
      <img src="{{ it.image }}" alt="">
      {% endif %}
      <div class="item-info">
        <div class="item-title">
          {{ it.title }}
          {% if it.detail_error %}<span class="error-badge">跳过: {{ it.detail_error }}</span>{% endif %}
        </div>
        <div class="item-meta">
          <span class="price">{{ it.price_text }}</span> &nbsp;|&nbsp;
          店铺: {{ it.shop_name | default('—') }}
          {% if it.detail and it.detail.location %} &nbsp;|&nbsp; 所在地: {{ it.detail.location }}{% endif %}
          {% if it.detail and it.detail.business_model %} &nbsp;|&nbsp; 经营模式: {{ it.detail.business_model }}{% endif %}
        </div>
        {% if it.detail and it.detail.params %}
        <div class="params">参数: {{ it.detail.params | join('； ') }}</div>
        {% endif %}
        {% if it.screenshot %}
        <img class="screenshot" src="{{ it.screenshot }}" alt="page screenshot">
        {% endif %}
      </div>
    </div>
    {% endfor %}
  </div>
</body>
</html>
